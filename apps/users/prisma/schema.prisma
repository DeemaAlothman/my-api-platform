generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  username  String     @unique
  email     String     @unique
  fullName  String?
  password  String
  status    UserStatus @default(ACTIVE)

  employee      Employee?
  roles         UserRole[]
  notifications Notification[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String

  revoked   Boolean  @default(false)
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model Employee {
  id             String    @id @default(uuid())
  employeeNumber String    @unique
  firstNameAr    String
  lastNameAr     String
  firstNameEn    String?
  lastNameEn     String?
  email          String    @unique
  phone          String?
  mobile         String?
  nationalId     String?
  gender         Gender
  dateOfBirth    DateTime?
  nationality    String?
  maritalStatus  MaritalStatus?

  // Relations
  departmentId   String
  department     Department @relation(fields: [departmentId], references: [id])

  jobTitleId     String?
  jobTitle       JobTitle?  @relation(fields: [jobTitleId], references: [id])

  jobGradeId     String?
  jobGrade       JobGrade?  @relation(fields: [jobGradeId], references: [id])

  managerId      String?
  manager        Employee?  @relation("EmployeeManager", fields: [managerId], references: [id])
  subordinates   Employee[] @relation("EmployeeManager")

  managedDepartments Department[] @relation("DepartmentManager")

  userId         String?    @unique
  user           User?      @relation(fields: [userId], references: [id])

  // Employment
  hireDate       DateTime
  contractType   ContractType
  contractEndDate DateTime?
  employmentStatus EmploymentStatus @default(ACTIVE)

  // Salary
  basicSalary    Decimal?  @db.Decimal(15, 2)
  salaryCurrency String?   @default("SYP")

  // Biometric
  fingerprintId  String?

  // Hiring
  probationPeriod    ProbationPeriod?
  interviewEvaluation InterviewEvaluation?

  // Probation Evaluation Result (set by evaluation-service when probation is completed)
  probationResult      ProbationResult?
  probationCompletedAt DateTime?

  // Personal Info (extra)
  profilePhoto       String?
  bloodType          BloodType?
  familyMembersCount Int?
  chronicDiseases    String?
  currentAddress     String?
  isSmoker           Boolean?
  educationLevel     EducationLevel?
  universityYear     Int?
  religion           String?

  // Education & Experience
  yearsOfExperience      Int?
  certificate1           String?
  specialization1        String?
  certificateAttachment1 String?
  certificate2           String?
  specialization2        String?
  certificateAttachment2 String?

  // Attachments
  attachments          EmployeeAttachment[]
  trainingCertificates TrainingCertificate[]
  allowances           EmployeeAllowance[]
  custodies            Custody[]
  onboardingWorkflows  OnboardingWorkflow[]

  deletedAt      DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([departmentId])
  @@index([managerId])
  @@index([employeeNumber])
  @@map("employees")
}

model EmployeeAttachment {
  id         String   @id @default(uuid())
  employeeId String
  fileUrl    String
  fileName   String

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@index([employeeId])
  @@map("employee_attachments")
}

model TrainingCertificate {
  id            String   @id @default(uuid())
  employeeId    String
  name          String
  attachmentUrl String?

  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())

  @@index([employeeId])
  @@map("training_certificates")
}

model EmployeeAllowance {
  id         String        @id @default(uuid())
  employeeId String
  type       AllowanceType
  amount     Decimal       @db.Decimal(15, 2)

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([employeeId])
  @@map("employee_allowances")
}

enum Gender {
  MALE
  FEMALE
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum ContractType {
  FIXED_TERM
  INDEFINITE
  TEMPORARY
  TRAINEE
}

enum AllowanceType {
  FOOD
  PREVIOUS_EXPERIENCE
  ACADEMIC_DEGREE
  WORK_NATURE
  RESPONSIBILITY
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
}

enum BloodType {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum EducationLevel {
  ILLITERATE
  PRIMARY
  SECONDARY
  DIPLOMA
  UNIVERSITY
  POSTGRADUATE
}

enum ProbationPeriod {
  ONE_MONTH
  TWO_MONTHS
  THREE_MONTHS
}

enum InterviewEvaluation {
  EXCELLENT
  VERY_GOOD
  GOOD
  ACCEPTABLE
  POOR
}

enum ProbationResult {
  CONFIRM_POSITION
  EXTEND_PROBATION
  TRANSFER_POSITION
  TERMINATE
}

model Department {
  id        String   @id @default(uuid())
  code      String   @unique
  nameAr    String
  nameEn    String?
  nameTr    String?

  parentId  String?
  parent    Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentHierarchy")

  managerId String?
  manager   Employee? @relation("DepartmentManager", fields: [managerId], references: [id])

  employees Employee[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([code])
  @@map("departments")
}

model JobGrade {
  id          String   @id @default(uuid())
  code        String   @unique
  nameAr      String
  nameEn      String?
  color       String?
  minSalary   Decimal? @db.Decimal(15, 2)
  maxSalary   Decimal? @db.Decimal(15, 2)
  description String?
  isActive    Boolean  @default(true)

  jobTitles   JobTitle[]
  employees   Employee[]

  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("job_grades")
}

model JobTitle {
  id          String    @id @default(uuid())
  code        String    @unique
  nameAr      String
  nameEn      String?
  nameTr      String?
  description String?

  gradeId     String?
  grade       JobGrade? @relation(fields: [gradeId], references: [id])

  employees   Employee[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("job_titles")
}

model Role {
  id             String   @id @default(uuid())
  name           String   @unique
  displayNameAr  String
  displayNameEn  String?
  description    String?

  users          UserRole[]
  permissions    RolePermission[]

  deletedAt      DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String
  description String?
  module      String

  roles       RolePermission[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("permissions")
}

model UserRole {
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  roleId    String
  role      Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  assignedAt   DateTime   @default(now())

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Custody {
  id           String          @id @default(uuid())

  name         String
  description  String?
  serialNumber String?         @unique
  category     CustodyCategory @default(OTHER)

  employeeId   String
  employee     Employee        @relation(fields: [employeeId], references: [id])
  assignedDate DateTime
  returnedDate DateTime?

  status       CustodyStatus   @default(WITH_EMPLOYEE)
  notes        String?

  attachments  CustodyAttachment[]

  createdBy    String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?

  @@index([employeeId])
  @@index([status])
  @@index([serialNumber])
  @@map("custodies")
}

model CustodyAttachment {
  id        String   @id @default(uuid())
  custodyId String
  fileUrl   String
  fileName  String

  custody   Custody  @relation(fields: [custodyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([custodyId])
  @@map("custody_attachments")
}

enum CustodyStatus {
  WITH_EMPLOYEE
  RETURNED
  DAMAGED
  LOST
}

enum CustodyCategory {
  ELECTRONICS
  FURNITURE
  VEHICLE
  TOOLS
  KEYS
  UNIFORM
  OTHER
}

model Notification {
  id        String             @id @default(uuid())
  userId    String
  type      NotificationType
  titleAr   String
  titleEn   String
  messageAr String
  messageEn String
  isRead    Boolean            @default(false)
  data      Json?
  readAt    DateTime?
  createdAt DateTime           @default(now())

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  LEAVE_REQUEST_SUBMITTED
  LEAVE_REQUEST_APPROVED
  LEAVE_REQUEST_REJECTED
  LEAVE_REQUEST_CANCELLED
  ATTENDANCE_ALERT
  ATTENDANCE_JUSTIFICATION
  EVALUATION_ASSIGNED
  EVALUATION_SUBMITTED
  PROBATION_REMINDER
  ONBOARDING_TASK
  OFFBOARDING_TASK
  DOCUMENT_EXPIRY
  GENERAL
}

// ─── Onboarding / Offboarding ───────────────────────────────────────────────

model OnboardingTemplate {
  id          String                   @id @default(uuid())
  type        WorkflowType
  nameAr      String
  nameEn      String
  description String?
  isDefault   Boolean                  @default(false)

  tasks       OnboardingTemplateTask[]
  workflows   OnboardingWorkflow[]

  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  deletedAt   DateTime?

  @@index([type])
  @@map("onboarding_templates")
}

model OnboardingTemplateTask {
  id            String              @id @default(uuid())
  templateId    String
  titleAr       String
  titleEn       String
  descriptionAr String?
  descriptionEn String?
  assignedTo    TaskAssignee
  order         Int                 @default(0)
  daysFromStart Int                 @default(0)

  template      OnboardingTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  workflowTasks OnboardingWorkflowTask[]

  @@index([templateId])
  @@map("onboarding_template_tasks")
}

model OnboardingWorkflow {
  id           String                   @id @default(uuid())
  employeeId   String
  templateId   String
  type         WorkflowType
  status       WorkflowStatus           @default(IN_PROGRESS)
  startDate    DateTime
  targetDate   DateTime?
  completedAt  DateTime?
  notes        String?

  employee     Employee                 @relation(fields: [employeeId], references: [id])
  template     OnboardingTemplate       @relation(fields: [templateId], references: [id])
  tasks        OnboardingWorkflowTask[]

  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([employeeId])
  @@index([status])
  @@map("onboarding_workflows")
}

model OnboardingWorkflowTask {
  id             String              @id @default(uuid())
  workflowId     String
  templateTaskId String
  titleAr        String
  titleEn        String
  assignedTo     TaskAssignee
  assignedUserId String?
  status         TaskStatus          @default(PENDING)
  dueDate        DateTime?
  completedAt    DateTime?
  notes          String?

  workflow       OnboardingWorkflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  templateTask   OnboardingTemplateTask @relation(fields: [templateTaskId], references: [id])

  @@index([workflowId])
  @@index([status])
  @@map("onboarding_workflow_tasks")
}

enum WorkflowType {
  ONBOARDING
  OFFBOARDING
}

enum WorkflowStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum TaskAssignee {
  HR
  IT
  MANAGER
  EMPLOYEE
  OTHER
}
