generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["jobs"]
}

// =============================================
// الشاغر الوظيفي
// =============================================
model InterviewPosition {
  id               String         @id @default(uuid())
  jobTitle         String
  department       String
  sectorName       String?
  workType         WorkType       @default(FULL_TIME)
  workMode         WorkMode       @default(ON_SITE)
  committeeMembers  Json           @default("[]")
  interviewDate     DateTime?
  status            PositionStatus @default(OPEN)
  requiresLanguage  Boolean        @default(true)
  requiresComputer  Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  technicalQuestions TechnicalQuestion[]
  evaluations        InterviewEvaluation[]
  candidates         Candidate[]

  @@schema("jobs")
}

enum WorkType {
  FULL_TIME
  PART_TIME

  @@schema("jobs")
}

enum WorkMode {
  ON_SITE
  REMOTE
  HYBRID

  @@schema("jobs")
}

enum PositionStatus {
  OPEN
  CLOSED
  SUSPENDED

  @@schema("jobs")
}

// =============================================
// معايير الصفات الشخصية (ثابتة)
// =============================================
model PersonalCriterion {
  id           String   @id @default(uuid())
  nameAr       String
  description  String?
  maxScore     Int      @default(5)
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  scores PersonalCriteriaScore[]

  @@schema("jobs")
}

// =============================================
// معايير المهارات الحاسوبية (ثابتة)
// =============================================
model ComputerCriterion {
  id           String   @id @default(uuid())
  nameAr       String
  description  String?
  maxScore     Int      @default(5)
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  scores ComputerCriteriaScore[]

  @@schema("jobs")
}

// =============================================
// الأسئلة التقنية لكل شاغر
// =============================================
model TechnicalQuestion {
  id           String    @id @default(uuid())
  positionId   String
  question     String
  maxScore     Int       @default(10)
  displayOrder Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  position InterviewPosition      @relation(fields: [positionId], references: [id])
  scores   TechnicalQuestionScore[]

  @@schema("jobs")
}

// =============================================
// تقييم المقابلة الرئيسي
// =============================================
model InterviewEvaluation {
  id               String              @id @default(uuid())
  positionId       String
  jobApplicationId String              @unique
  candidateName    String
  residence        String?
  dateOfBirth      DateTime?           @db.Date
  maritalStatus    String?
  contactNumber    String?
  academicDegree   String?
  yearsOfExperience Float?
  expectedSalary   Float?
  expectedJoinDate DateTime?           @db.Date
  additionalConditions    String?
  salaryAfterConfirmation Float?
  generalNotes     String?
  personalScore    Float?
  technicalScore   Float?
  computerScore    Float?
  totalScore       Float?
  decision         EvaluationDecision?
  proposedSalary   Float?
  evaluatorId      String?
  evaluatedAt      DateTime?
  isTransferred    Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  position       InterviewPosition       @relation(fields: [positionId], references: [id])
  personalScores PersonalCriteriaScore[]
  technicalScores TechnicalQuestionScore[]
  computerScores ComputerCriteriaScore[]

  @@schema("jobs")
}

enum EvaluationDecision {
  ACCEPTED
  REFERRED_TO_OTHER
  DEFERRED
  REJECTED

  @@schema("jobs")
}

// =============================================
// درجات الصفات الشخصية
// =============================================
model PersonalCriteriaScore {
  evaluationId String
  criterionId  String
  score        Int

  evaluation InterviewEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  criterion  PersonalCriterion   @relation(fields: [criterionId], references: [id])

  @@id([evaluationId, criterionId])
  @@schema("jobs")
}

// =============================================
// درجات الأسئلة التقنية
// =============================================
model TechnicalQuestionScore {
  evaluationId String
  questionId   String
  score        Int

  evaluation InterviewEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  question   TechnicalQuestion   @relation(fields: [questionId], references: [id])

  @@id([evaluationId, questionId])
  @@schema("jobs")
}

// =============================================
// درجات المهارات الحاسوبية
// =============================================
model ComputerCriteriaScore {
  evaluationId String
  criterionId  String
  score        Int

  evaluation InterviewEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  criterion  ComputerCriterion   @relation(fields: [criterionId], references: [id])

  @@id([evaluationId, criterionId])
  @@schema("jobs")
}

// =============================================
// Sprint 5 — Candidate Pipeline
// =============================================

enum CandidateStage {
  PENDING
  ELIGIBLE_FOR_INTERVIEW
  FINAL_ELIGIBLE
  CEO_APPROVAL
  REFERENCE_CHECK
  HIRED
  REJECTED

  @@schema("jobs")
}

enum CandidateSource {
  WEBSITE
  LINKEDIN
  INTERNAL_REFERRAL
  RECRUITMENT_AGENCY
  WALK_IN
  OTHER

  @@schema("jobs")
}

enum OfferStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED

  @@schema("jobs")
}

model Candidate {
  id             String          @id @default(uuid())
  positionId     String?
  firstNameAr    String
  lastNameAr     String
  firstNameEn    String?
  lastNameEn     String?
  email          String?
  phone          String
  nationalId     String?
  currentStage   CandidateStage  @default(PENDING)
  source         CandidateSource @default(WEBSITE)
  cvUrl          String?
  expectedSalary Decimal?        @db.Decimal(15, 2)
  notes          String?
  isTransferred  Boolean         @default(false)
  transferredEmployeeId String?
  rejectionReason String?
  reference1Name  String?
  reference1Phone String?
  reference2Name  String?
  reference2Phone String?
  createdBy      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  position        InterviewPosition?       @relation(fields: [positionId], references: [id])
  stageHistory    CandidateStageHistory[]
  offers          JobOffer[]
  referenceCheck  CandidateReferenceCheck?

  @@index([currentStage])
  @@index([positionId])
  @@map("candidates")
  @@schema("jobs")
}

model CandidateStageHistory {
  id          String         @id @default(uuid())
  candidateId String
  fromStage   CandidateStage?
  toStage     CandidateStage
  notes       String?
  changedBy   String?
  changedAt   DateTime       @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@map("candidate_stage_history")
  @@schema("jobs")
}

model JobOffer {
  id             String      @id @default(uuid())
  candidateId    String
  positionId     String?
  basicSalary    Decimal     @db.Decimal(15, 2)
  currency       String      @default("SYP")
  startDate      DateTime?
  expiresAt      DateTime?
  status         OfferStatus @default(DRAFT)
  benefits       String?
  notes          String?
  sentAt         DateTime?
  respondedAt    DateTime?
  createdBy      String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([status])
  @@map("job_offers")
  @@schema("jobs")
}

model CandidateReferenceCheck {
  id                  String    @id @default(uuid())
  candidateId         String    @unique
  reference1ReportUrl String?
  reference2ReportUrl String?
  notes               String?
  checkedBy           String
  checkedAt           DateTime  @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_reference_checks")
  @@schema("jobs")
}
