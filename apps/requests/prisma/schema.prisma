generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RequestType {
  TRANSFER
  RESIGNATION
  REWARD
  OTHER
  PENALTY_PROPOSAL
  OVERTIME_EMPLOYEE
  OVERTIME_MANAGER
  BUSINESS_MISSION
  DELEGATION
  HIRING_REQUEST
  COMPLAINT
  PERMISSION
  ADVANCE
  JOB_CHANGE
  RIGHTS
  SPONSORSHIP
}

enum RequestStatus {
  DRAFT
  IN_APPROVAL
  PENDING_MANAGER
  PENDING_HR
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApproverRole {
  DIRECT_MANAGER
  DEPARTMENT_MANAGER
  TARGET_MANAGER
  HR
  CEO
  CFO
}

model Request {
  id              String        @id @default(uuid())
  requestNumber   String        @unique
  employeeId      String
  type            RequestType
  status          RequestStatus @default(DRAFT)
  reason          String?
  notes           String?
  attachmentUrl   String?
  details         Json?

  currentStepOrder  Int?
  targetEmployeeId  String?

  managerStatus     ApprovalStatus?
  managerReviewedBy String?
  managerReviewedAt DateTime?
  managerNotes      String?

  hrStatus      ApprovalStatus?
  hrReviewedBy  String?
  hrReviewedAt  DateTime?
  hrNotes       String?

  cancelReason String?
  cancelledAt  DateTime?
  cancelledBy  String?

  approvalSteps ApprovalStep[]
  history       RequestHistory[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([employeeId])
  @@index([type])
  @@index([status])
  @@map("requests")
}

model ApprovalWorkflow {
  id           String       @id @default(uuid())
  requestType  RequestType
  stepOrder    Int
  approverRole ApproverRole
  isRequired   Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([requestType, stepOrder])
  @@map("approval_workflows")
}

model ApprovalStep {
  id           String         @id @default(uuid())
  requestId    String
  stepOrder    Int
  approverRole ApproverRole
  status       ApprovalStatus @default(PENDING)
  reviewedBy   String?
  reviewedAt   DateTime?
  notes        String?

  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([requestId, stepOrder])
  @@index([requestId])
  @@map("approval_steps")
}

model RequestHistory {
  id          String   @id @default(uuid())
  requestId   String
  action      String
  fromStatus  String?
  toStatus    String
  performedBy String
  notes       String?
  createdAt   DateTime @default(now())

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("request_history")
}
